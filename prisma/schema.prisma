// ============================================================
// AgendaBot (MultiDigital) — Modelo de datos
// Multi-tenant, multi-rubro, agenda + chatbot + suscripciones
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// RUBROS Y PLANTILLAS
// Define qué campos captura la "ficha de cliente" de cada rubro
// (receta óptica, ficha estética, ficha de equipo, etc.)
// ------------------------------------------------------------

// AGENDAMIENTO: el cliente escribe primero y agenda un horario (óptica, estética, etc.)
// CATALOGO_ROTATIVO: el negocio inicia el contacto ofreciendo un catálogo que cambia
// seguido (panadería, rotisería, viandas, verdulería, carnicería, meal prep, etc.)
enum ModoOperacionRubro {
  AGENDAMIENTO
  CATALOGO_ROTATIVO
}

model RubroTemplate {
  id            String   @id @default(uuid())
  clave         String   @unique // "optica", "centro_estetico", "salud_independiente", "mantencion_tecnica", "panaderia_gourmet", "otro"
  nombre        String
  modoOperacion ModoOperacionRubro @default(AGENDAMIENTO)
  camposFicha   Json     // definición de los campos de la ficha de cliente para este rubro
  serviciosBase Json     // lista de tipos de servicio sugeridos (ej. "Examen de la vista") o catálogo sugerido si es CATALOGO_ROTATIVO
  automatizacionesBase Json // reglas de automatización sugeridas (ej. recordatorio de control anual)
  creadoEn      DateTime @default(now())

  empresas Empresa[]
}

// ------------------------------------------------------------
// EMPRESAS (TENANTS)
// Cada cliente de AgendaBot es una Empresa (Ahorróptica, etc.)
// ------------------------------------------------------------
model Empresa {
  id              String   @id @default(uuid())
  nombre          String   // "Ahorróptica"
  sucursal        String?  // "Sucursal Lautaro"
  rut             String?
  telefonoContacto String?


  rubroTemplate   RubroTemplate @relation(fields: [rubroTemplateId], references: [id])
  rubroTemplateId String

  logoUrl         String? // URL del logo del negocio (para el panel, el chatbot, y la futura landing page)

  // Personalización del negocio — pensado para que cada empresa lo cargue
  // ella misma vía el panel de "Información del negocio" (pendiente de UI),
  // en vez de que MultiDigital lo cargue a mano por script.
  direccion         String? // dirección real, usada en confirmaciones/recordatorios del bot
  notaAgendamiento  String? // texto libre que el bot puede citar sobre políticas de agendamiento (ej. "cupos limitados, avisar con anticipación si no puede asistir")
  informacionAdicional String? @db.Text // FAQ/precios/promociones que el bot puede citar TAL CUAL — nunca debe inventar nada fuera de esto
  requiereRut       Boolean @default(false) // si true, agendar_cita exige RUT del cliente antes de crear la cita
   sitioWeb        String? // URL del sitio web, si tiene — usado para extracción asistida de información

  // WhatsApp Business propio del cliente (no de MultiDigital)
  whatsappNumeroId String? // phone_number_id de Meta
  whatsappWabaId   String? // ID de la WhatsApp Business Account
  whatsappToken    String? // token de acceso (almacenar cifrado en producción)

  googleCalendarId    String?
  googleRefreshToken  String? // almacenar cifrado en producción

  creadoEn        DateTime @default(now())

  usuarios        Usuario[]
  recursos        RecursoAgendable[]
  clientes        Cliente[]
  servicios       Servicio[]
  citas           Cita[]
  listaEspera     ListaEspera[]
  conversaciones  Conversacion[]
  ventas          Venta[]
  suscripcion     Suscripcion?
  contratosAceptados ContratoAceptado[]

  // Catálogo rotativo (panadería, rotisería, viandas, etc.)
  productos       Producto[]
  campanasEnvio   CampanaEnvio[]
  pedidos         Pedido[]

  // Créditos prepagados de campaña
  billeteraCreditos      BilleteraCreditos?
  ordenesCompraCreditos  OrdenCompraCreditos[]

  // Demos comerciales
  esDemo         Boolean @default(false)
  demosAsignadas DemoAsignada[]

  @@index([rubroTemplateId])
}

// ------------------------------------------------------------
// USUARIOS DEL PANEL (staff de cada empresa)
// ------------------------------------------------------------
enum RolUsuario {
  ADMIN       // dueño/administrador de la empresa cliente
  RECEPCION   // solo agenda, sin ver datos clínicos
  PROFESIONAL // ve su propia disponibilidad y ficha clínica de sus clientes
}

model Usuario {
  id        String     @id @default(uuid())
  empresa   Empresa    @relation(fields: [empresaId], references: [id])
  empresaId String

  nombre    String
  email     String     @unique
  passwordHash String
  rol       RolUsuario

  // Si el usuario es un profesional, se vincula a su recurso agendable
  recursoAgendable   RecursoAgendable? @relation(fields: [recursoAgendableId], references: [id])
  recursoAgendableId String?

  creadoEn  DateTime   @default(now())

  @@index([empresaId])
}

// ------------------------------------------------------------
// RECURSOS AGENDABLES (profesionales, boxes, máquinas, etc.)
// ------------------------------------------------------------
model RecursoAgendable {
  id        String   @id @default(uuid())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String

  nombre    String   // "Dra. Camila Reyes"
  tipo      String   @default("profesional") // "profesional" | "box" | "equipo"

  duracionCitaMinutos   Int @default(30)
  anticipacionMinimaMin Int @default(120) // minutos mínimos antes de poder agendar
  horizonteAgendaDias   Int @default(28)

  horarios     HorarioSemanal[]
  bloqueos     Bloqueo[]
  citas        Cita[]
  usuarios     Usuario[]

  @@index([empresaId])
}

model HorarioSemanal {
  id                 String   @id @default(uuid())
  recurso            RecursoAgendable @relation(fields: [recursoAgendableId], references: [id])
  recursoAgendableId String

  diaSemana  Int      // 0 = domingo ... 6 = sábado
  horaInicio String   // "09:00"
  horaFin    String   // "13:00"
  activo     Boolean  @default(true)

  @@index([recursoAgendableId])
}

model Bloqueo {
  id                 String   @id @default(uuid())
  recurso            RecursoAgendable @relation(fields: [recursoAgendableId], references: [id])
  recursoAgendableId String

  fechaInicio DateTime
  fechaFin    DateTime
  motivo      String?

  @@index([recursoAgendableId])
}

// ------------------------------------------------------------
// SERVICIOS (tipos de atención que ofrece cada empresa)
// ------------------------------------------------------------
model Servicio {
  id        String   @id @default(uuid())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String

  nombre    String   // "Examen de la vista", "Limpieza facial", "Mantención preventiva"
  duracionMinutos Int?
  activo    Boolean  @default(true)

  citas     Cita[]

  @@index([empresaId])
}

// ------------------------------------------------------------
// CLIENTES / PACIENTES (genérico, ficha configurable por rubro)
// ------------------------------------------------------------
model Cliente {
  id        String   @id @default(uuid())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String

  nombre    String
  rut       String?
  telefono  String?
  email     String?
  fechaNacimiento DateTime?

  // Datos específicos del rubro (receta óptica, ficha estética, ficha de equipo, etc.)
  // La estructura de este JSON la define RubroTemplate.camposFicha
  // Los campos "clínicos" dentro de fichaJson deben filtrarse por rol al leer (RECEPCION no los ve)
  fichaJson Json?

  consentimientoDatos Boolean @default(false)
  consentimientoFecha DateTime?

  // Si es false, se excluye de los envíos masivos de campañas (catálogo rotativo).
  // No afecta su capacidad de escribir y recibir respuesta normalmente.
  optInCampanas Boolean @default(true)

  // Control de recordatorios automáticos (evita reenviar el mismo aviso
  // repetidamente). Se agregarán más campos similares si se suman otros
  // tipos de recordatorio por rubro (ej. próxima sesión, mantención).
  recordatorioControlAnualEnviadoEn DateTime?

  creadoEn  DateTime @default(now())

  citas       Cita[]
  listaEspera ListaEspera[]
  ventas      Venta[]
  conversaciones Conversacion[]
  pedidos     Pedido[]

  @@index([empresaId])
  @@index([telefono])
}

// ------------------------------------------------------------
// CITAS
// ------------------------------------------------------------
enum EstadoCita {
  PENDIENTE
  CONFIRMADA
  CANCELADA
  COMPLETADA
  NO_ASISTIO
}

model Cita {
  id        String   @id @default(uuid())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String

  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  clienteId String

  recurso   RecursoAgendable @relation(fields: [recursoAgendableId], references: [id])
  recursoAgendableId String

  servicio  Servicio? @relation(fields: [servicioId], references: [id])
  servicioId String?

  fechaHoraInicio DateTime
  fechaHoraFin    DateTime
  estado    EstadoCita @default(PENDIENTE)

  // Control del recordatorio de confirmación (24h antes, luego cada 1h,
  // hasta 3 intentos — ver src/jobs/confirmarCitasProximas.js). No confundir
  // con recordatorioControlAnualEnviadoEn en Cliente, que es un recordatorio
  // anual distinto (control de la vista), no de una cita puntual.
  confirmacionIntentos      Int      @default(0)
  confirmacionUltimoEnvioEn DateTime?
  canceladaPorNoConfirmar   Boolean  @default(false)

  googleEventId String? // id del evento creado en Google Calendar

  origenCanal String @default("whatsapp") // "whatsapp" | "panel" | "widget"

  creadoEn  DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([empresaId, fechaHoraInicio])
  @@index([clienteId])
  @@index([recursoAgendableId])
}

// ------------------------------------------------------------
// LISTA DE ESPERA
// ------------------------------------------------------------
enum EstadoListaEspera {
  ESPERANDO
  OFRECIDO
  CONFIRMADO
  EXPIRADO
  CANCELADO
}

model ListaEspera {
  id        String   @id @default(uuid())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String

  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  clienteId String

  preferenciaRecursoId String?  // null = cualquier profesional
  preferenciaFranja    String?  // ej. "AM", "PM", "esta semana"

  estado    EstadoListaEspera @default(ESPERANDO)
  ofrecidoEn DateTime?
  expiraEn   DateTime?

  creadoEn  DateTime @default(now())

  @@index([empresaId])
}

// ------------------------------------------------------------
// CONVERSACIONES DE WHATSAPP (historial + estado del chatbot)
// ------------------------------------------------------------
model Conversacion {
  id        String   @id @default(uuid())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String

  cliente   Cliente? @relation(fields: [clienteId], references: [id])
  clienteId String?

  telefono  String   // número del paciente, por si aún no existe como Cliente
  mensajes  Json      // arreglo de {rol, contenido, timestamp}
  escaladoAHumano Boolean @default(false)

  actualizadoEn DateTime @updatedAt
  creadoEn  DateTime @default(now())

  @@index([empresaId])
  @@index([telefono])
}

// ------------------------------------------------------------
// VENTAS (compras del cliente: armazones, sesiones, mantenciones, etc.)
// ------------------------------------------------------------
enum EstadoPagoVenta {
  PAGADO
  PENDIENTE
}

model Venta {
  id        String   @id @default(uuid())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String

  cliente   Cliente  @relation(fields: [clienteId], references: [id])
  clienteId String

  descripcion String  // "Armazón Ray-Ban + cristales progresivos"
  monto       Int     // en CLP
  estadoPago  EstadoPagoVenta @default(PENDIENTE)

  fichaAsociadaId String? // referencia opcional a la receta/ficha vigente al momento de la venta

  creadoEn  DateTime @default(now())

  @@index([empresaId])
  @@index([clienteId])
}

// ------------------------------------------------------------
// SUSCRIPCIÓN Y FACTURACIÓN
// ------------------------------------------------------------
enum PlanSuscripcion {
  PLAN_A
  PLAN_B
  PLAN_C
  PLAN_INICIO_LEGACY // condiciones especiales de Ahorróptica, pre-grilla A/B/C
}

enum EstadoSuscripcion {
  PENDIENTE_PAGO
  ACTIVA
  PAUSADA_POR_IMPAGO
  CANCELADA
}

model Suscripcion {
  id        String   @id @default(uuid())
  empresa   Empresa  @relation(fields: [empresaId], references: [id])
  empresaId String   @unique

  plan      PlanSuscripcion
  estado    EstadoSuscripcion @default(PENDIENTE_PAGO)

  tokenFlow String?  // token de tarjeta tokenizada en Flow

  fechaInicio           DateTime @default(now())
  fechaCambioPrecio     DateTime? // fechaInicio + 6 meses, para planes con promo inicial
  montoMensualActual    Int
  citasIncluidas        Int
  precioCitaExcedente   Int

  fechaProximoCobro         DateTime
  fechaProximoCobroHosting  DateTime

  intentosFallidosConsecutivos Int @default(0)
  fechaUltimoPago               DateTime?

  pagos     Pago[]

  @@index([empresaId])
}

enum TipoPago {
  MENSUALIDAD
  HOSTING
  PRIMER_PAGO
  EXCEDENTE
}

enum EstadoPago {
  EXITOSO
  FALLIDO
}

model Pago {
  id             String   @id @default(uuid())
  suscripcion    Suscripcion @relation(fields: [suscripcionId], references: [id])
  suscripcionId  String

  tipo           TipoPago
  monto          Int
  valorUfDelDia  Float?   // solo si tipo = HOSTING
  estado         EstadoPago
  flowOrderId    String?
  boletaFolio    String?

  fecha          DateTime @default(now())

  @@index([suscripcionId])
}

// ------------------------------------------------------------
// CATÁLOGO ROTATIVO (panadería, rotisería, viandas, verdulería,
// carnicería, meal prep, etc.) — el negocio ofrece proactivamente
// un catálogo que cambia seguido, en vez de esperar que el cliente
// pida hora. Ver ModoOperacionRubro.
// ------------------------------------------------------------
model Producto {
  id          String   @id @default(uuid())
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  empresaId   String

  nombre      String    // "Croissant", "Roll de canela", "Pan ciabatta"
  descripcion String?
  precio      Int       // CLP
  unidad      String   @default("unidad") // "unidad" | "kg" | "docena" | "porción"
  activo      Boolean  @default(true) // disponible en el catálogo general del negocio

  creadoEn    DateTime @default(now())

  pedidoItems PedidoItem[]

  @@index([empresaId])
}

// Configuración de CUÁNDO se dispara la preparación de un envío.
// El disparo en la hora configurada solo crea un EnvioRealizado en
// estado BORRADOR — el panadero elige los productos de ese envío
// específico y lo envía manualmente desde el panel.
model CampanaEnvio {
  id          String   @id @default(uuid())
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  empresaId   String

  nombre      String    // "Panes de la mañana"
  diasSemana  Int[]     // 0 = domingo ... 6 = sábado. Ej. [1,3,5] = lun/mié/vie
  hora        String    // "08:00", hora local de la empresa

  // Nombre exacto de la plantilla de WhatsApp aprobada en Meta que abre
  // la conversación (con botón de respuesta rápida "Ver el menú de hoy").
  plantillaWhatsapp String

  activa      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  // Segmentación: si está activa, el envío no va a TODOS los clientes con
  // optInCampanas=true, sino solo a quienes cumplan el historial de compra
  // definido acá — reduce el costo real de Meta al no mandarle a quien no
  // le interesa, y sirve para ofertas dirigidas ("solo a quienes ya
  // compraron ciabatta antes").
  segmentada Boolean @default(false)
  segmentoDias Int?              // ventana de tiempo a evaluar (ej. 30 = "últimos 30 días")
  segmentoMontoMinimoClp Int?    // debe haber gastado al menos esto en esa ventana (null = sin mínimo)
  segmentoProductoIds String[] @default([])   // debe haber comprado al menos uno de estos productos (vacío = cualquiera)

  enviosRealizados EnvioRealizado[]

  @@index([empresaId])
}

enum EstadoEnvioRealizado {
  BORRADOR  // creado por el cron a la hora programada, esperando que el panadero elija productos
  ENVIADO   // el panadero ya eligió productos y se disparó el mensaje a los clientes
  CANCELADO
}

// Snapshot de CADA disparo real de una campaña — permite trazabilidad
// (qué se ofreció y a cuántos) y agrupar los pedidos de ese envío.
model EnvioRealizado {
  id          String   @id @default(uuid())
  campana     CampanaEnvio @relation(fields: [campanaId], references: [id])
  campanaId   String

  fechaProgramada DateTime // el día para el que se preparó (para no duplicar el mismo día)
  estado      EstadoEnvioRealizado @default(BORRADOR)

  // Snapshot de qué productos y precios se ofrecieron en este envío específico
  // (arreglo de { productoId, nombre, precio, unidad }). Se llena al enviar.
  productosOfrecidosJson Json?

  fechaHoraEnvio    DateTime?
  destinatariosCount Int?

  // Costo real estimado en CLP de este envío (destinatariosCount × tarifa
  // Meta vigente al momento de enviar). Se guarda al enviar para llevar
  // historial de gasto, aunque la tarifa de Meta cambie más adelante.
  costoEstimadoClp Int?

  mensajeDelDia String? @db.VarChar(80)

  creadoEn    DateTime @default(now())

  pedidos     Pedido[]

  @@index([campanaId])
  @@index([campanaId, fechaProgramada])
}

enum EstadoPedido {
  PENDIENTE
  CONFIRMADO
  LISTO
  ENTREGADO
  CANCELADO
}

model Pedido {
  id          String   @id @default(uuid())
  empresa     Empresa  @relation(fields: [empresaId], references: [id])
  empresaId   String

  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  clienteId   String

  envioRealizado   EnvioRealizado? @relation(fields: [envioRealizadoId], references: [id])
  envioRealizadoId String?

  estado      EstadoPedido @default(PENDIENTE)
  fechaRetiro DateTime?
  notas       String?

  // Cuando el cliente elige un producto de la lista, queda acá mientras
  // el bot espera que responda "¿cuántos quieres?". Null cuando no hay
  // ninguna pregunta de cantidad pendiente.
  productoPendienteId String?

  creadoEn    DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  items       PedidoItem[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([envioRealizadoId])
}

model PedidoItem {
  id          String   @id @default(uuid())
  pedido      Pedido   @relation(fields: [pedidoId], references: [id])
  pedidoId    String

  producto    Producto @relation(fields: [productoId], references: [id])
  productoId  String

  cantidad    Int      @default(1)
  precioUnitario Int   // copiado al momento del pedido, no referencia flotante al precio actual

  @@index([pedidoId])
  @@index([productoId])
}

// ------------------------------------------------------------
// CONTRATO DE ACEPTACIÓN (registro legal del clickwrap)
// ------------------------------------------------------------
model ContratoAceptado {
  id            String   @id @default(uuid())
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  empresaId     String

  versionContrato String  // ej. "plan-inicio-v1"
  aceptoTerminos      Boolean
  aceptoDatosPacientes Boolean

  nombreQuienAcepta String
  emailQuienAcepta  String
  ipAddress         String?
  userAgent         String?

  fechaAceptacion   DateTime @default(now())

  @@index([empresaId])
}

// ------------------------------------------------------------
// CRÉDITOS PREPAGADOS DE CAMPAÑA (catálogo rotativo)
// Cada crédito = 1 mensaje de categoría Marketing enviado a 1 cliente.
// Precio de venta: $149 CLP/crédito (cubre costo real Meta $78,49 + IVA + margen).
// ------------------------------------------------------------
model BilleteraCreditos {
  id            String   @id @default(cuid())
  empresaId     String   @unique
  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  saldoActual   Int      @default(0) // en créditos, no en CLP
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  movimientos   MovimientoCredito[]
}

model MovimientoCredito {
  id            String              @id @default(cuid())
  billeteraId   String
  billetera     BilleteraCreditos   @relation(fields: [billeteraId], references: [id])
  tipo          TipoMovimientoCredito
  cantidad      Int                 // positivo en COMPRA, negativo en CONSUMO/AJUSTE_NEGATIVO
  saldoResultante Int               // saldo de la billetera justo después de este movimiento (auditoría)
  montoClp      Int?                // solo aplica a COMPRA — cuánto pagó realmente en CLP
  campanaEnvioId String?            // referencia opcional al EnvioRealizado que gatilló el consumo
  nota          String?             // ej. "Compra paquete 500 créditos", "Envío campaña Roll de canela 14/07"
  creadoEn      DateTime            @default(now())
}

enum TipoMovimientoCredito {
  COMPRA           // el cliente compró créditos (vía Flow.cl u otro medio)
  CONSUMO          // se descontaron créditos por un envío real de campaña
  AJUSTE_MANUAL    // corrección manual (ej. reembolso por error nuestro), positivo o negativo
}

// Registro de cada intento de compra de créditos, desde que el cliente ingresa
// la cantidad hasta que Flow.cl confirma (o no) el pago. Sirve para conciliar
// el webhook y para no perder rastro de compras que quedan a medias.
model OrdenCompraCreditos {
  id              String    @id @default(cuid())
  empresaId       String
  empresa         Empresa   @relation(fields: [empresaId], references: [id])
  cantidadCreditos Int      // ingresada libremente por el cliente, mínimo 50
  montoClp        Int
  estado          EstadoOrdenCredito @default(PENDIENTE)
  flowToken       String?   @unique // token de Flow.cl, una vez integrado el SDK real
  creadoEn        DateTime  @default(now())
  actualizadoEn   DateTime  @updatedAt
}

enum EstadoOrdenCredito {
  PENDIENTE
  PAGADA
  RECHAZADA
  EXPIRADA
}

// ------------------------------------------------------------
// DEMOS COMERCIALES
// Vincula el teléfono de un prospecto con la Empresa de demo que debe
// simular el bot, cuando el mensaje llega al número dedicado a demos
// (no a un número real de cliente). El estado de la conversación de
// demo (en qué paso va, historial de la simulación) vive acá mismo,
// separado por completo del modelo Conversacion que usa el motor real.
// ------------------------------------------------------------
model DemoAsignada {
  id              String   @id @default(cuid())
  telefono        String   @unique
  empresaDemoId   String
  empresaDemo     Empresa  @relation(fields: [empresaDemoId], references: [id])
  nombreProspecto String?
  creadoEn        DateTime @default(now())
  actualizadoEn   DateTime @updatedAt
  vendedor        Vendedor? @relation(fields: [vendedorId], references: [id])
  vendedorId      String?
  eliminadoEn         DateTime? // si no es null, esta demo fue "eliminada" por el vendedor (soft-delete)
  telefonoOriginal    String?   // el teléfono real, conservado para historial/métricas después de liberar `telefono`



  paso                Int   @default(0)
  historialSimulacion Json?
  carritoDemoJson     Json? // productos seleccionados en la simulación de catálogo: [{productoId, nombre, precio, cantidad}]
  citaDemoJson        Json? // simulación de la cita elegida en la demo de agendamiento: {servicio, fecha, hora, nombre, edad}
  checkoutDemoJson    Json? // estado del checkout simulado en la demo de catálogo: {paso, productoPendienteId, nombre, formaPago, tipoEntrega, direccion}
}

model Vendedor {
  id           String   @id @default(uuid())
  nombre       String
  email        String   @unique
  passwordHash String
  activo       Boolean  @default(true)
  creadoEn     DateTime @default(now())

  demosCreadas DemoAsignada[]
}

