{
  "name": "agendabot-backend",
  "version": "0.1.0",
  "description": "Backend multi-tenant de AgendaBot (MultiDigital): agenda, chatbot WhatsApp + Claude, clientes y suscripciones",
  "main": "src/server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:studio": "prisma studio",
    "seed": "node prisma/seed.js",
    "cron:recordatorios": "node src/jobs/enviarRecordatorios.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@prisma/client": "^5.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "prisma": "^5.20.0"
  }
}
