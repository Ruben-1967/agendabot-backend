# Base de datos (Render Postgres, o local)
DATABASE_URL="postgresql://usuario:password@host:5432/agendabot?schema=public"

# Servidor
PORT=3000

# WhatsApp Business API (Meta) - token de verificación del webhook
WHATSAPP_VERIFY_TOKEN="elige-un-token-secreto-aqui"

# Anthropic (Claude Haiku para el chatbot)
ANTHROPIC_API_KEY=""

# Flow.cl (pagos recurrentes) - se agregan cuando se integre el cobro
FLOW_API_KEY=""
FLOW_SECRET_KEY=""
