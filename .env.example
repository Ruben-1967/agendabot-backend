# Base de datos (Render Postgres, o local)
DATABASE_URL="postgresql://usuario:password@host:5432/agendabot?schema=public"

# Servidor
PORT=3000

# WhatsApp Business API (Meta) - token de verificación del webhook
WHATSAPP_VERIFY_TOKEN="elige-un-token-secreto-aqui"

# Anthropic (Claude Haiku para el chatbot)
ANTHROPIC_API_KEY=""

# Panel administrativo/profesional (login)
JWT_SECRET="genera-un-string-largo-y-aleatorio-aqui"
# URL(s) del Static Site del panel en Render, separadas por coma si hay más de una
# (ej. dominio de preview + dominio final). Si se deja vacía, se permite cualquier origen (solo dev).
PANEL_FRONTEND_URL=""

# Flow.cl (pagos recurrentes) - se agregan cuando se integre el cobro
FLOW_API_KEY=""
FLOW_SECRET_KEY=""
